PORT=5001

# MongoDB Atlas
MONGO_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/highsky_db

CLIENT_URL=http://localhost:3001
FRONTEND_URL=http://localhost:8080

# ── JWT Secrets (tách riêng admin và student) ─────────────
JWT_ADMIN_SECRET=your_admin_secret_key_here
JWT_STUDENT_SECRET=your_student_secret_key_here
JWT_ISS=highsky_platform

# ── SMTP Email (Gmail) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM="Your Name" <your_gmail@gmail.com>

# ── App config ────────────────────────────────────────────
NODE_ENV=development
API_BASE_URL=http://localhost:5001
